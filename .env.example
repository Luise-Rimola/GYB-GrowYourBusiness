# Kopieren nach .env und Werte setzen. Auf Vercel: Project → Settings → Environment Variables.

# PostgreSQL (z. B. Neon, Supabase)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Optional (Supabase): Direktverbindung ohne Session-Pooler — für `npm run db:seed` / migrate, wenn der Pooler "max clients" meldet.
# Dashboard → Project Settings → Database → Connection string → URI → Modus "Direct connection" (Host db.*.supabase.co, Port 5432)
# DIRECT_URL="postgresql://postgres.[ref]:[PASSWORD]@db.[ref].supabase.co:5432/postgres"

# Session-Cookie (JWT), mindestens 16 Zeichen
AUTH_SECRET="mindestens-16-zeichen-geheim"

# E-Mail über Resend (https://resend.com) — in Production Pflicht für Verifizierungs-Mails
RESEND_API_KEY="re_..."
# Verifizierte Absenderadresse bei Resend (Domain grow-your-business.online in Resend verifizieren)
EMAIL_FROM="Grow Your Business <noreply@grow-your-business.online>"
# Fester Empfänger für anonymisierte Evaluations-Pakete
EVALUATION_MAIL_TO="Luise-kassia.rimole@iubh-fernstudium.de"

# Nur lokal: 1 = Login umgehen (niemals in Production setzen)
# DEV_AUTH_BYPASS=1

# Nur lokal/Demo: 1 = alle Workflow-Sperren in der UI ignorieren (niemals in Production setzen)
# UNLOCK_ALL_WORKFLOWS=1

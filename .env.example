# Kopieren nach .env und Werte setzen. Auf Vercel: Project → Settings → Environment Variables.

# PostgreSQL (z. B. Neon, Supabase)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Session-Cookie (JWT), mindestens 16 Zeichen
AUTH_SECRET="mindestens-16-zeichen-geheim"

# E-Mail über Resend (https://resend.com) — in Production Pflicht für Verifizierungs-Mails
RESEND_API_KEY="re_..."
# Verifizierte Absenderadresse bei Resend (Domain grow-your-business.online in Resend verifizieren)
EMAIL_FROM="Grow Your Business <noreply@grow-your-business.online>"

# Nur lokal: 1 = Login umgehen (niemals in Production setzen)
# DEV_AUTH_BYPASS=1

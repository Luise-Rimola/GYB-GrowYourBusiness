# Kopieren nach .env und Werte setzen. Auf Vercel: Project → Settings → Environment Variables.

# PostgreSQL — bei Supabase **Transaction pooler** (Port 6543), nicht Session (5432), sonst: MaxClientsInSessionMode
# Siehe: https://www.prisma.io/docs/orm/overview/databases/supabase
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"
# Direktverbindung nur für `prisma migrate` (Host db.<projekt>.supabase.co, Port 5432)
DIRECT_URL="postgresql://USER:PASSWORD@db.PROJEKT_REF.supabase.co:5432/postgres?sslmode=require"

# Session-Cookie (JWT), mindestens 16 Zeichen
AUTH_SECRET="mindestens-16-zeichen-geheim"

# E-Mail über Resend (https://resend.com) — in Production Pflicht für Verifizierungs-Mails
RESEND_API_KEY="re_..."
# Verifizierte Absenderadresse bei Resend (Domain grow-your-business.online in Resend verifizieren)
EMAIL_FROM="Grow Your Business <noreply@grow-your-business.online>"
# Fester Empfänger für anonymisierte Evaluations-Pakete
EVALUATION_MAIL_TO="Luise-kassia.rimole@iubh-fernstudium.de"

# Nur lokal: 1 = Login umgehen (niemals in Production setzen)
# DEV_AUTH_BYPASS=1

# Nur lokal/Demo: 1 = alle Workflow-Sperren in der UI ignorieren (niemals in Production setzen)
# UNLOCK_ALL_WORKFLOWS=1

# Optional: Brave Search API für LinkedIn-/Firmensuche bei Profil-Anreicherung (ohne Key: DuckDuckGo-Fallback)
# BRAVE_SEARCH_API_KEY=

# Optionale LLM-Defaults für Setup-Formulare (werden angezeigt, wenn nichts in DB gespeichert ist)
# Du kannst LLM_*_DEFAULT ODER LLM_* ODER KIMI_* verwenden.
# LLM_API_URL_DEFAULT="https://api.moonshot.ai/v1"
# LLM_API_KEY_DEFAULT="sk-..."
# LLM_MODEL_DEFAULT="kimi-k2.5"
